# ============================================================================
# BOT_CLAWS_YULIIA — пример конфигурации
# Скопируй в .env и заполни реальными значениями.  .env в репозиторий не идёт.
# ============================================================================

# --- Telegram ---------------------------------------------------------------
# Токен от @BotFather
BOT_TOKEN=
# Твой Telegram user id (узнать: https://t.me/userinfobot)
OWNER_CHAT_ID=
# IANA timezone, см. https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
OWNER_TZ=Asia/Almaty

# --- STT провайдер: openai | yandex -----------------------------------------
STT_PROVIDER=openai

# --- OpenAI (Whisper для STT + GPT для парсинга) ----------------------------
OPENAI_API_KEY=

# --- Yandex SpeechKit (нужен только если STT_PROVIDER=yandex) ---------------
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# --- LLM-парсер -------------------------------------------------------------
LLM_MODEL=gpt-4o-mini
# Если не задан — используется OPENAI_API_KEY
LLM_API_KEY=

# --- Инфраструктура ---------------------------------------------------------
REDIS_URL=redis://redis:6379/0
DB_PATH=/data/bot.db

# --- UX ---------------------------------------------------------------------
# Через сколько минут idle FSM-состояние очищается из Redis
FSM_TTL_MINUTES=30
LOG_LEVEL=INFO
