# ============================================================================
# BOT_CLAWS_YULIIA — пример конфигурации
# Скопируй в .env и заполни реальными значениями.  .env в репозиторий не идёт.
# ============================================================================

# --- Telegram ---------------------------------------------------------------
# Токен от @BotFather
BOT_TOKEN=
# Telegram user id мастера, который пользуется ботом каждый день. Сюда
# уходят уведомления о записях, /start меню — это «основной» юзер.
# Узнать свой id: https://t.me/userinfobot
OWNER_CHAT_ID=
# (опционально) Дополнительные админы, которые тоже могут писать боту.
# Через запятую. Например, разработчик, который держит деплой:
#   ADMIN_CHAT_IDS=123456789,987654321
# Уведомления (напоминания о записях) им НЕ приходят — только OWNER_CHAT_ID.
ADMIN_CHAT_IDS=
# IANA timezone, см. https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
OWNER_TZ=Asia/Almaty
# (опционально) Override назначения weekly backup-файлов:
#   - если задан → бэкапы идут только сюда (например, id приватного канала
#     -1001234567890);
#   - если НЕ задан, но задан ADMIN_CHAT_IDS → бэкапы идут всем админам;
#   - если оба пусты → fallback на OWNER_CHAT_ID.
# Бэкап всегда отправляется без звука (disable_notification=true).
BACKUP_CHAT_ID=

# --- STT (распознавание голоса) ---------------------------------------------
# faster_whisper: локально, FREE, +500 МБ к Docker-образу (рекомендуется)
# openai_whisper: облачный fallback, $0.006/мин, нужен OPENAI_API_KEY
STT_PROVIDER=faster_whisper
# tiny | base | small | medium | large-v3 — больше = лучше качество, медленнее
WHISPER_MODEL_SIZE=small
# Длиннее voice → отбой с подсказкой
VOICE_MAX_DURATION_SEC=60

# --- LLM (парсинг команд) ---------------------------------------------------
# openrouter: агрегатор моделей, FREE 200 RPD, no-gate (рекомендуется)
# groq: Groq Cloud (llama-3.3-70b), FREE 6000 RPD — иногда профиль не активирован
# gemini: Gemini Flash, FREE 1500 RPD (но free tier бывает обнулённым)
# openai_mini: gpt-4o-mini, ~$0.30 за 1k команд — нужен OPENAI_API_KEY
# anthropic_haiku: Claude Haiku 4.5, ~$3 за 1k команд — нужен ANTHROPIC_API_KEY
LLM_PROVIDER=openrouter
# Опционально: явно указать модель (если не задано — дефолт провайдера)
# LLM_MODEL=

# --- API keys ---------------------------------------------------------------
# Получить здесь: https://openrouter.ai/keys  (бесплатно)
OPENROUTER_API_KEY=
# Получить здесь: https://console.groq.com/keys  (бесплатно, требует профиль)
GROQ_API_KEY=
# Получить здесь: https://aistudio.google.com/apikey  (бесплатно)
GEMINI_API_KEY=
# Используется для openai_whisper STT и/или openai_mini LLM
OPENAI_API_KEY=
# Используется только если LLM_PROVIDER=anthropic_haiku
ANTHROPIC_API_KEY=

# --- Инфраструктура ---------------------------------------------------------
REDIS_URL=redis://redis:6379/0
DB_PATH=/data/bot.db

# --- UX ---------------------------------------------------------------------
# Через сколько минут idle FSM-состояние очищается из Redis
FSM_TTL_MINUTES=30
LOG_LEVEL=INFO
